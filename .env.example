# OpenAI (optional — only needed when LLM_PROVIDER=openai)
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# Gemini (optional — only needed when LLM_PROVIDER=gemini)
# ─────────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# Groq (optional — only needed when LLM_PROVIDER=groq-hybrid)
# ─────────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# LLM Provider: "openai" | "ollama" | "gemini" | "gemini-hybrid" | "groq-hybrid"
# Default: "groq-hybrid" (local embeddings + Groq Llama3, recommended)
#   - groq-hybrid: local embeddings + Groq cloud LLM (super fast & free)
#   - gemini-hybrid: local embeddings + Gemini cloud LLM
#   - ollama: 100% local (needs ~5 GB RAM for llama3)
#   - gemini: all-cloud (embeddings + LLM via Gemini API)
#   - openai: OpenAI API (requires API key + paid plan)
# ─────────────────────────────────────────────────────────────────────────────
LLM_PROVIDER=groq-hybrid

# ─────────────────────────────────────────────────────────────────────────────
# Models
# ─────────────────────────────────────────────────────────────────────────────
# Used only when LLM_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o
EMBEDDING_DIM=1536

# Used when LLM_PROVIDER=ollama (default)
OLLAMA_BASE_URL=http://ollama:11434
# Available local models: llama3:8b, mistral:7b
OLLAMA_MODEL=llama3:8b
# sentence-transformers/all-MiniLM-L6-v2 produces 384-dim vectors
OLLAMA_EMBEDDING_DIM=384

# Used only when LLM_PROVIDER=gemini (full cloud)
# Gemini models: gemini-2.0-flash-lite (LLM) + gemini-embedding-001 (embeddings)
# Note: gemini-hybrid uses local embeddings, so only the LLM is cloud-based
GEMINI_EMBEDDING_DIM=3072

# ─────────────────────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─────────────────────────────────────────────────────────────────────────────
# API settings
# ─────────────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:80

# ─────────────────────────────────────────────────────────────────────────────
# RAG settings
# ─────────────────────────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5
MAX_HISTORY_MESSAGES=10
